{
  "name": "martingranados.com",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "test": "vitest run",
    "typecheck": "astro check",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "sync-projects": "echo 'sync-projects placeholder — implemented in M5' && exit 0",
    "verify": "pnpm typecheck && pnpm lint && pnpm test && pnpm build",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.6",
    "astro": "^6.3.7"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.7.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.7"
  },
  "lint-staged": {
    "*.{js,ts,astro,md,mdx,json,yml,yaml,css}": [
      "prettier --write"
    ],
    "*.{js,ts,astro}": [
      "eslint --fix"
    ]
  }
}
